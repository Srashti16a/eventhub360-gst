datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id               String            @id @default(uuid())
  title            String
  category         String            // e.g. "Corporate Gala", "Spring Wedding", "Charity Gala", "Product Launch"
  date             DateTime
  guests           Guest[]
  fleetAssignments FleetAssignment[]
  transfers        TransferSchedule[]
  fleetAnalytics   FleetAnalytics[]
  entrances        Entrance[]
  checkIns         CheckIn[]

  campaigns        Campaign[]
  qrPasses         QRPass[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Hotel {
  id        String   @id @default(uuid())
  name      String
  guests    Guest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id        String   @id @default(uuid())
  name      String   // e.g. "Table 1"
  capacity  Int      @default(10)
  guests    Guest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guest {
  id              String             @id @default(uuid())
  name            String
  avatar          String
  email           String
  phone           String
  status          String             // "CONFIRMED", "PENDING", "DECLINED"
  isVip           Boolean            @default(false)
  isSpeaker       Boolean            @default(false)
  isBridalParty   Boolean            @default(false)
  isPrimaryGuest  Boolean            @default(false)
  
  assignedHotelId String?
  assignedHotel   Hotel?             @relation(fields: [assignedHotelId], references: [id])
  
  eventId         String
  event           Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  tableId         String?
  table           Table?             @relation(fields: [tableId], references: [id])
  seatNumber      Int?
  
  groupId         String?
  group           GuestGroup?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  
  transfers       TransferSchedule[]
  
  checkedIn       Boolean            @default(false)
  checkinTime     DateTime?
  checkinEntrance String?
  checkinStatus   String             @default("SUCCESS") // "SUCCESS", "FLAGGED"
  
  mealPreference  String?
  allergies       String?
  numberOfGuests  Int                @default(1)
  notes           String?
  
  vipTier         VipTier            @default(ATTENDEE)
  checkIns        CheckIn[]
  communicationLogs CommunicationLog[]
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  // Guest profile related relations
  accommodation   GuestAccommodation?
  transportation  GuestTransportation?
  seating         GuestSeating?
  communications  GuestCommunication[]
  dietaryPreferences GuestDietaryPreference[]
  specialRequests GuestSpecialRequest[]
  conciergeNotes  GuestConciergeNote[]
  communicationHistory CommunicationHistory[]
  qrPasses        QRPass[]
}

// Enums for communication and transportation statuses
enum CommunicationType {
  EMAIL
  WHATSAPP
  SMS
  PHONE_CALL
}

enum TransportationStatus {
  SCHEDULED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model GuestAccommodation {
  id                 String   @id @default(uuid())
  guestId            String   @unique
  hotelName          String?
  roomType           String?
  roomNumber         String?
  reservationStatus  String?
  checkIn            DateTime?
  checkOut           DateTime?
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuestTransportation {
  id                 String   @id @default(uuid())
  guestId            String   @unique
  pickupLocation     String?
  dropLocation       String?
  vehicle            String?
  driverName         String?
  driverPhone        String?
  pickupTime         DateTime?
  trackingLink       String?
  transportationStatus TransportationStatus?
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuestSeating {
  id                 String   @id @default(uuid())
  guestId            String   @unique
  floor              String?
  section            String?
  tableNumber        String?
  seatNumber         String?
  seatingMapImage    String?
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuestCommunication {
  id                 String   @id @default(uuid())
  guestId            String
  communicationType  CommunicationType
  title              String
  description        String
  createdAt          DateTime @default(now())
  deliveryStatus     DeliveryStatus
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model GuestConciergeNote {
  id                 String   @id @default(uuid())
  guestId            String
  note               String
  createdBy          String
  createdAt          DateTime @default(now())
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model GuestDietaryPreference {
  id                 String   @id @default(uuid())
  guestId            String
  preference         String
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model GuestSpecialRequest {
  id                 String   @id @default(uuid())
  guestId            String
  request            String
  guest              Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id            String                 @id @default(uuid())
  name          String
  type          String                 // e.g. "Sedan", "SUV", "Van", "Minibus"
  licenseNumber String                 @unique
  capacity      Int
  status        String                 @default("Available") // "On Route", "Staged", "Maintenance", "Available"

  assignments   FleetAssignment[]
  transfers     TransferSchedule[]
  maintenances  VehicleMaintenance[]
  activityLogs  FleetActivityLog[]
  optimizations RouteOptimizationLog[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model FleetAssignment {
  id         String   @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status     String   @default("Active") // "Active", "Completed", "Cancelled"
  assignedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt


}

model TransportRoute {
  id           String             @id @default(uuid())
  routeName    String
  startLocation String
  endLocation   String
  distanceKm   Float
  durationMins Int
  status       String             @default("Active") // "Active", "Inactive"
  optimizedAt  DateTime?
  transfers    TransferSchedule[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model TransferSchedule {
  id              String          @id @default(uuid())
  guestId         String
  guest           Guest           @relation(fields: [guestId], references: [id], onDelete: Cascade)
  eventId         String
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  transferType    String          // "Airport Pickup", "Airport Dropoff", "Hotel Transfer", "VIP Transport", "Other"
  pickupLocation  String
  dropoffLocation String
  scheduledTime   DateTime
  routeId         String?
  route           TransportRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)
  vehicleId       String?
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  status          String          @default("Scheduled") // "Scheduled", "In Transit", "Completed", "Cancelled"
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model FleetActivityLog {
  id           String   @id @default(uuid())
  activityType String   // "Route Completed", "Dispatch Alert", "Maintenance Alert", "Assignment Update", "Driver Status Change", "Conflict Detected"
  severity     String   @default("Info") // "Info", "Warning", "Critical"
  message      String
  vehicleId    String?
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
}

model VehicleMaintenance {
  id              String    @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceType String    // "Oil Change", "Tire Rotation", "Engine Repair", "Fuel Warning", "Routine Inspection", "Other"
  description     String?
  scheduledDate   DateTime
  completedDate   DateTime?
  status          String    @default("Scheduled") // "Scheduled", "In Progress", "Completed", "Cancelled"
  cost            Float     @default(0.0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FleetAnalytics {
  id               String   @id @default(uuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalVehicles    Int      @default(0)
  activeDrivers    Int      @default(0)
  onRouteVehicles  Int      @default(0)
  efficiencyRating Float    @default(0.0)
  recordedDate     DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([eventId, recordedDate])
}

model RouteOptimizationLog {
  id                 String   @id @default(uuid())
  vehicleId          String
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  optimizationResult String   // Will store JSON serialized as string
  generatedBy        String
  createdAt          DateTime @default(now())
}

model GuestGroup {
  id                 String   @id @default(uuid())
  name               String
  category           String
  status             String   @default("Active") // "Active", "Draft", "Archived"
  isVipGroup         Boolean  @default(false)
  primaryGuestId     String?
  location           String?
  transportation     String?
  specialRequirement String?
  
  members            Guest[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum CheckInStatus {
  SUCCESS
  FLAGGED
}

enum VipTier {
  PLATINUM
  KEYNOTE
  GOLD
  ATTENDEE
}

model Entrance {
  id          String    @id @default(uuid())
  name        String    // e.g. "North Gate", "VIP Gate"
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkIns    CheckIn[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([eventId, name])
}

model CheckIn {
  id          String        @id @default(uuid())
  guestId     String
  guest       Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entranceId  String
  entrance    Entrance      @relation(fields: [entranceId], references: [id], onDelete: Cascade)
  status      CheckInStatus
  checkedInAt DateTime      @default(now())
  staffId     String?
  staff       Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([guestId])
  @@index([eventId])
  @@index([entranceId])
  @@index([staffId])
}

model Staff {
  id               String    @id @default(uuid())
  name             String    // e.g. "Julian Rossi", "Sarah Jenkins"
  role             String    // e.g. "Event Manager", "Gate Operator"
  assignedEntrance String?   // e.g. "North Gate"
  status           String    @default("Active") // "Active", "Inactive"
  checkIns         CheckIn[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum DeliveryStatus {
  DELIVERED
  SENT
  FAILED
  PENDING
  READ
}

model CommunicationLog {
  id               String               @id @default(uuid())
  recipientId      String?
  guest            Guest?               @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  recipientName    String
  recipientContact String
  channel          CommunicationChannel
  status           DeliveryStatus
  deliveryResult   String
  latencyMs        Int                  @default(0)
  headerInfo       Json?
  payloadData      Json?
  retryHistory     Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([recipientId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model RouteConfiguration {
  id               String               @id @default(uuid())
  channel          CommunicationChannel @unique
  activeProvider   String
  isRerouted       Boolean              @default(false)
  updatedAt        DateTime             @updatedAt
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum CampaignTargetType {
  GUEST_GROUP
  VIP
  SPEAKERS
  CONFIRMED
  PENDING
  ALL_GUESTS
}

model Campaign {
  id             String                 @id @default(uuid())
  title          String
  subject        String?
  description    String?
  channel        CommunicationType      // Reuses existing CommunicationType enum
  targetType     CampaignTargetType
  targetId       String?                // References GuestGroup.id if targetType is GUEST_GROUP
  eventId        String?
  event          Event?                 @relation(fields: [eventId], references: [id], onDelete: SetNull)
  scheduledAt    DateTime?
  status         CampaignStatus         @default(DRAFT)
  createdBy      String                 @default("system")
  communications CommunicationHistory[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model CommunicationHistory {
  id            String            @id @default(uuid())
  guestId       String
  guest         Guest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  campaignId    String?
  campaign      Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  channel       CommunicationType // Reuses existing CommunicationType enum
  status        DeliveryStatus    @default(PENDING) // Reuses existing DeliveryStatus enum
  sentAt        DateTime          @default(now())
  openedAt      DateTime?
  clickedAt     DateTime?
  failureReason String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum QRPassType {
  VIP
  ATTENDEE
  STAFF
  SPEAKER
  VENDOR
  MEDIA
}

enum QRPassStatus {
  ACTIVE
  SCANNED
  REVOKED
  EXPIRED
}

enum ScanStatus {
  SUCCESS
  FAILED_EXPIRED
  FAILED_REVOKED
  FAILED_DUPLICATE
  FAILED_INVALID
}

model QRPass {
  id            String            @id @default(uuid())
  guestId       String
  guest         Guest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  passType      QRPassType
  status        QRPassStatus      @default(ACTIVE)
  qrCode        String            @unique // Unique QR token (UUID)
  passNumber    String            @unique // Unique human-readable code
  expiresAt     DateTime?
  generatedAt   DateTime          @default(now())
  lastScannedAt DateTime?
  downloadCount Int               @default(0)
  createdBy     String            @default("system")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  scanHistory   ScanHistory[]
  deliveryLogs  PassDeliveryLog[]

  @@unique([guestId, eventId]) // Prevent duplicate passes for the same guest and event
}

model ScanHistory {
  id           String       @id @default(uuid())
  qrPassId     String
  qrPass       QRPass       @relation(fields: [qrPassId], references: [id], onDelete: Cascade)
  scanLocation String?
  scannerName  String?
  deviceId     String?
  scanTime     DateTime     @default(now())
  scanStatus   ScanStatus
  notes        String?
  createdAt    DateTime     @default(now())
}

model PassDeliveryLog {
  id            String            @id @default(uuid())
  qrPassId      String
  qrPass            QRPass            @relation(fields: [qrPassId], references: [id], onDelete: Cascade)
  channel       CommunicationType // Reuses existing CommunicationType enum
  status        String            // "SENT", "FAILED"
  sentAt        DateTime          @default(now())
  failureReason String?
  createdAt     DateTime          @default(now())
}